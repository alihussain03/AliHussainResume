---
layout: layouts/base.njk
title: ""
---
<header class="hero">
  <div class="wrap reveal">
    <span class="eyebrow">{{ site.title }} — {{ site.location }}</span>
    <h1 class="display">{{ home.hero.heading }}</h1>
    <p>{{ home.hero.intro }}</p>

    <div class="paths">
      {% for path in home.paths %}
      <div class="path-card">
        <span class="eyebrow">{{ path.eyebrow }}</span>
        <h2>{{ path.title }}</h2>
        <p>{{ path.description }}</p>
        <div class="row-inline">
          {% for btn in path.buttons %}
          {% if btn.cv %}
          <a class="btn btn-{{ btn.variant }}" href="{{ site.cv }}" download="Ali-Hussain-CV.pdf">{{ btn.label }}</a>
          {% else %}
          <a class="btn btn-{{ btn.variant }}" href="{{ btn.href }}">{{ btn.label }}</a>
          {% endif %}
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</header>

<section>
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Selected results</span>
      <h2>Work that moved the numbers</h2>
    </div>
    <div class="highlights">
      {% for h in home.highlights %}
      <div class="highlight">
        <div class="num">{{ h.num }}</div>
        <p>{{ h.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section>
  <div class="wrap">
    <div class="trust">
      <span>{{ home.trustCert }}</span>
      <span class="sep"></span>
      <a class="link" href="{{ site.github }}">github.com/alihussain03</a>
      <span class="sep"></span>
      <a class="link" href="{{ site.linkedin }}">linkedin.com/in/alihussain03</a>
    </div>
  </div>
</section>
