<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} — {{ site.name }}{% else %}{{ site.name }} — {{ site.title }}{% endif %}</title>
<meta name="description" content="{{ description or 'Backend-focused software engineer with 6+ years of experience in enterprise systems, Spring Boot microservices, and cloud platforms. Based in Tampere, Finland.' }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Spectral:wght@400;500;600&family=Instrument+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/tokens.css">
<link rel="stylesheet" href="/assets/css/main.css">
</head>
<body>

<div class="topbar">
  <div class="wrap">
    <a class="logo" href="/">Ali Hussain<span class="mark">.</span></a>
    <nav class="nav" aria-label="Main">
      <a href="/about/"{% if page.url == '/about/' %} aria-current="page"{% endif %}>About</a>
      <a href="/services/"{% if page.url == '/services/' %} aria-current="page"{% endif %}>Services</a>
      <a href="/projects/"{% if page.url == '/projects/' %} aria-current="page"{% endif %}>Projects</a>
      <a href="/blog/"{% if '/blog/' in page.url %} aria-current="page"{% endif %}>Blog</a>
      <a href="/contact/"{% if page.url == '/contact/' %} aria-current="page"{% endif %}>Contact</a>
    </nav>
    <details class="mobile-menu">
      <summary>Menu</summary>
      <div class="mobile-links">
        <a href="/about/">About</a>
        <a href="/services/">Services</a>
        <a href="/projects/">Projects</a>
        <a href="/blog/">Blog</a>
        <a href="/contact/">Contact</a>
      </div>
    </details>
  </div>
</div>

<main>
{{ content | safe }}
</main>

<footer>
  <div class="wrap">
    <p>{{ site.name }} — {{ site.title }}, {{ site.location }}.</p>
    <nav aria-label="Footer">
      {% for link in site.footerLinks %}
      <a href="{{ link.href }}">{{ link.label }}</a>
      {% endfor %}
    </nav>
  </div>
</footer>

<script>
  /* Close the mobile menu after a link is tapped. */
  document.querySelectorAll('.mobile-links a').forEach(function (a) {
    a.addEventListener('click', function () {
      var d = a.closest('details');
      if (d) d.removeAttribute('open');
    });
  });
</script>

</body>
</html>
