---
layout: layouts/page.njk
title: Projects
eyebrow: Case studies
intro: Selected work, framed the way clients think about it — the problem, what I did, and the result.
permalink: /projects/
---
<section>
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Impact highlights</span>
      <h2>Proof points from production systems</h2>
      <p>Results from professional work on enterprise systems at Nokia and Confiz.</p>
    </div>
    <div class="highlights">
      {% for h in projects.highlights %}
      <div class="highlight">
        <div class="num">{{ h.num }}</div>
        <p>{{ h.text }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section>
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Project</span>
      <h2>Selected work</h2>
    </div>
    {% for case in projects.cases %}
    <article class="case">
      <span class="pill">{{ case.tag }}</span>
      <h2>{{ case.title }}</h2>
      <dl>
        <div>
          <dt>Problem</dt>
          <dd>{{ case.problem }}</dd>
        </div>
        <div>
          <dt>What I did</dt>
          <dd>
            <ul>
              {% for item in case.did %}<li>{{ item }}</li>{% endfor %}
            </ul>
          </dd>
        </div>
        <div>
          <dt>Result</dt>
          <dd>{{ case.result }}</dd>
        </div>
      </dl>
      {% if case.tech.length %}
      <div class="row-inline">
        {% for t in case.tech %}<span class="pill">{{ t }}</span>{% endfor %}
      </div>
      {% endif %}
    </article>
    {% endfor %}
    <div class="row-inline" style="margin-top:var(--s6)">
      <a class="btn btn-secondary" href="{{ site.github }}">More on GitHub</a>
      <a class="btn btn-text" href="/contact/">Have a similar project? →</a>
    </div>
  </div>
</section>
