---
layout: layouts/page.njk
title: Contact
eyebrow: Get in touch
intro: Whether you're hiring or have a project in mind, send me a message below and I'll get back to you.
permalink: /contact/
---
<section>
  <div class="wrap">
    <div class="contact-grid">
      <div class="path-card">
        <span class="eyebrow">Hiring?</span>
        <h2>Recruiters</h2>
        <p>Grab the CV, look through my GitHub, or send me a message about a role.</p>
        <div class="stack">
          <div class="row-inline">
            <a class="btn btn-primary" href="{{ site.cv }}" download="Ali-Hussain-CV.pdf">Download CV</a>
            <a class="btn btn-secondary" href="#message">Send a message</a>
          </div>
        </div>
      </div>
      <div class="path-card">
        <span class="eyebrow">Have a project?</span>
        <h2>Clients</h2>
        <p>Tell me what you're building — I'll reply with how I can help and when I'm available.</p>
        <div class="stack">
          <div class="row-inline">
            <a class="btn btn-primary" href="#message">Start a project</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="message">
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Message</span>
      <h2>Send me a message</h2>
    </div>
    <form class="contact-form" action="https://formsubmit.co/{{ site.email }}" method="POST">
      <input type="hidden" name="_subject" value="New message from alihussain website">
      <input type="hidden" name="_next" value="https://alihussain03.github.io/AliHussainResume/thanks/">
      <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px">
      <div class="field">
        <label for="cf-name">Your name <span class="req" aria-hidden="true">*</span></label>
        <input class="input" id="cf-name" type="text" name="name" autocomplete="name" required>
      </div>
      <div class="field">
        <label for="cf-email">Your email <span class="req" aria-hidden="true">*</span></label>
        <input class="input" id="cf-email" type="email" name="email" autocomplete="email" inputmode="email" placeholder="you@company.com" required>
      </div>
      <div class="field">
        <label for="cf-message">Message <span class="req" aria-hidden="true">*</span></label>
        <textarea class="input" id="cf-message" name="message" rows="6" required></textarea>
      </div>
      <p class="form-note"><span aria-hidden="true">*</span> Required. I'll only use your email to reply.</p>
      <button class="btn btn-primary" type="submit" data-sending="Sending…">Send message</button>
    </form>
  </div>
</section>

<section>
  <div class="wrap">
    <div class="section-head">
      <span class="eyebrow">Elsewhere</span>
      <h2>Where to find me</h2>
    </div>
    <ul class="contact-list">
      <li><span class="k">GitHub</span><a class="link" href="{{ site.github }}">github.com/alihussain03</a></li>
      <li><span class="k">LinkedIn</span><a class="link" href="{{ site.linkedin }}">linkedin.com/in/alihussain03</a></li>
      <li><span class="k">Location</span>{{ site.location }}</li>
    </ul>
  </div>
</section>

<script>
  /* Progressive enhancement: show a sending state on submit.
     The form still works with JavaScript disabled. */
  document.querySelectorAll('.contact-form').forEach(function (form) {
    form.addEventListener('submit', function () {
      var btn = form.querySelector('button[type="submit"]');
      if (btn && !btn.disabled) {
        btn.dataset.label = btn.textContent;
        btn.textContent = btn.dataset.sending || 'Sending…';
        btn.setAttribute('aria-busy', 'true');
        btn.disabled = true;
      }
    });
  });
</script>
